{
  "name": "dramatis-ssr",
  "version": "0.0.0",
  "type": "module",
  "description": "Server-side rendered (SSR) application that provides listings for theatrical productions, materials, and associated data.",
  "author": "https://github.com/andygout",
  "license": "MS-RSL",
  "main": "src/server.js",
  "scripts": {
    "format": "prettier \"**/*.{js,jsx,json,css,md,yml}\" --write",
    "format-check": "prettier \"**/*.{js,jsx,json,css,md,yml}\" --check",
    "lint": "eslint",
    "lint-fix": "eslint --fix",
    "lintspaces": "git ls-files ':!:*.png' | xargs lintspaces -e .editorconfig",
    "lint-check": "npm run lint && npm run lintspaces",
    "lint-staged": "lint-staged",
    "unit-test": "node --test",
    "build": "rollup --config",
    "watch": "rollup --config --watch",
    "node": "node --watch-path=built --watch-preserve-output --watch-path=public --watch-preserve-output --enable-source-maps built/main.js",
    "start": "concurrently --names \"watch,node\" --prefixColors \"yellow,green\" \"npm run watch\" \"npm run node\""
  },
  "lint-staged": {
    "*.{js,jsx,json,css,md,yml}": [
      "prettier --write"
    ],
    "*.{js,jsx}": [
      "eslint"
    ],
    "*.{js,jsx,json,css,md,yml}": [
      "lintspaces -e .editorconfig"
    ]
  },
  "pre-commit": [
    "lint-staged",
    "unit-test"
  ],
  "engines": {
    "node": "26.1.0",
    "npm": "11.14.1"
  },
  "volta": {
    "node": "26.1.0",
    "npm": "11.14.1"
  },
  "dependencies": {
    "accessible-autocomplete": "github:andygout/accessible-autocomplete#v2.0.1",
    "express": "5.2.1",
    "express-session": "1.19.0",
    "morgan": "1.10.1",
    "preact": "10.29.2",
    "preact-render-to-string": "6.7.0",
    "react": "npm:@preact/compat",
    "serve-favicon": "2.5.1"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "29.0.2",
    "@rollup/plugin-node-resolve": "16.0.3",
    "concurrently": "9.2.1",
    "eslint": "9.39.4",
    "eslint-config-preact": "2.0.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-import": "2.32.0",
    "globals": "17.6.0",
    "lint-staged": "17.0.5",
    "lintspaces-cli": "1.0.0",
    "postcss-import": "16.1.1",
    "pre-commit": "2.0.0",
    "prettier": "3.8.3",
    "rollup": "4.60.4",
    "rollup-plugin-copy": "3.5.0",
    "rollup-plugin-esbuild": "6.2.1",
    "rollup-plugin-postcss": "4.0.2"
  }
}
